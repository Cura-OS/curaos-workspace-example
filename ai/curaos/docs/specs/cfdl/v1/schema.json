{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.curaos.dev/cfdl/v1.json",
  "title": "CuraFlow Definition Language v1",
  "description": "Schema for CFDL workflow definitions consumed by workflow-core-service.",
  "type": "object",
  "required": [
    "id",
    "version",
    "metadata",
    "graph"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_.-]+$",
      "description": "Stable identifier for the workflow definition."
    },
    "version": {
      "type": "string",
      "description": "Semantic version of the workflow definition."
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "context": {
      "$ref": "#/$defs/context"
    },
    "graph": {
      "$ref": "#/$defs/graph"
    },
    "forms": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/form"
      }
    },
    "policies": {
      "$ref": "#/$defs/policies"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "$defs": {
    "metadata": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tenantScope": {
          "type": "string",
          "enum": [
            "shared",
            "tenant",
            "private"
          ]
        },
        "owner": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "context": {
      "type": "object",
      "properties": {
        "inputs": {
          "$ref": "#/$defs/typedMap"
        },
        "outputs": {
          "$ref": "#/$defs/typedMap"
        },
        "variables": {
          "$ref": "#/$defs/typedMap"
        }
      },
      "additionalProperties": false
    },
    "typedMap": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/dataType"
      }
    },
    "dataType": {
      "type": [
        "string",
        "object"
      ],
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "string",
            "number",
            "integer",
            "boolean",
            "datetime",
            "json",
            "uuid"
          ]
        },
        {
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "type": "string"
            },
            "items": {
              "$ref": "#/$defs/dataType"
            },
            "required": {
              "type": "boolean"
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "graph": {
      "type": "object",
      "required": [
        "nodes",
        "edges"
      ],
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/node"
          },
          "minItems": 1
        },
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/edge"
          }
        }
      },
      "additionalProperties": false
    },
    "node": {
      "type": "object",
      "required": [
        "id",
        "type",
        "name"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_.-]+$"
        },
        "type": {
          "type": "string",
          "enum": [
            "start.event",
            "end.event",
            "exclusive.gateway",
            "parallel.gateway",
            "inclusive.gateway",
            "event.gateway",
            "user.task",
            "service.task",
            "script.task",
            "timer.event",
            "signal.event",
            "message.event",
            "compensation.event",
            "subprocess"
          ]
        },
        "name": {
          "type": "string"
        },
        "lane": {
          "type": "string"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        },
        "ioBindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ioBinding"
          }
        },
        "conditions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/expression"
          }
        },
        "taskRef": {
          "$ref": "#/$defs/taskRef"
        },
        "extensions": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "edge": {
      "type": "object",
      "required": [
        "source",
        "target"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_.-]+$"
        },
        "source": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "condition": {
          "$ref": "#/$defs/expression"
        },
        "priority": {
          "type": "integer",
          "minimum": 0
        },
        "isDefault": {
          "type": "boolean"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "ioBinding": {
      "type": "object",
      "required": [
        "direction",
        "target"
      ],
      "properties": {
        "direction": {
          "type": "string",
          "enum": [
            "input",
            "output"
          ]
        },
        "source": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "transformation": {
          "$ref": "#/$defs/expression"
        }
      },
      "additionalProperties": false
    },
    "taskRef": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "form",
            "service",
            "script",
            "subprocess"
          ]
        },
        "key": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "options": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "form": {
      "type": "object",
      "required": [
        "id",
        "version",
        "layout"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_.-]+$"
        },
        "version": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "layout": {
          "type": "object",
          "description": "Component tree or reference understood by Flutter task renderer.",
          "additionalProperties": true
        },
        "bindings": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "policies": {
      "type": "object",
      "properties": {
        "sla": {
          "type": "string",
          "description": "ISO 8601 duration for expected completion."
        },
        "escalation": {
          "type": "object",
          "additionalProperties": true
        },
        "security": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "expression": {
      "type": "object",
      "required": [
        "language",
        "body"
      ],
      "properties": {
        "language": {
          "type": "string",
          "enum": [
            "cel",
            "jq",
            "spel",
            "sql",
            "javascript"
          ]
        },
        "body": {
          "type": "string"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    }
  }
}
