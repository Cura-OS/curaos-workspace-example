{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.curaos.dev/cbcf/v1.json",
  "title": "Cura Builder Composition Format v1",
  "description": "Schema for CBCF definitions used by CuraBuilder and site-core-service.",
  "type": "object",
  "required": [
    "id",
    "version",
    "metadata",
    "environment",
    "components",
    "layouts",
    "routes"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_.-]+$"
    },
    "version": {
      "type": "string"
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "environment": {
      "$ref": "#/$defs/environment"
    },
    "components": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/component"
      }
    },
    "layouts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/layout"
      }
    },
    "routes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/route"
      }
    },
    "bindings": {
      "$ref": "#/$defs/bindings"
    },
    "workflows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/workflowRef"
      }
    },
    "assets": {
      "$ref": "#/$defs/assets"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "$defs": {
    "metadata": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tenantScope": {
          "type": "string",
          "enum": ["shared", "tenant", "private"]
        },
        "owner": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "environment": {
      "type": "object",
      "required": ["renderTargets"],
      "properties": {
        "renderTargets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^flutter:(web|desktop|mobile)$"
          }
        },
        "devMode": {
          "type": "object",
          "properties": {
            "skipAuth": {
              "type": "boolean"
            },
            "assumedIdentity": {
              "type": "string"
            },
            "assumedTenant": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "component": {
      "type": "object",
      "required": ["id", "key"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_.-]+$"
        },
        "key": {
          "type": "string",
          "description": "Component registry key (e.g., ui.form.input.text)."
        },
        "version": {
          "type": "string"
        },
        "variant": {
          "type": "string"
        },
        "props": {
          "type": "object",
          "additionalProperties": true
        },
        "bindings": {
          "$ref": "#/$defs/componentBindings"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "componentBindings": {
      "type": "object",
      "properties": {
        "input": {
          "$ref": "#/$defs/bindingExpression"
        },
        "output": {
          "$ref": "#/$defs/bindingExpression"
        },
        "events": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/bindingExpression"
         }
        }
      },
      "additionalProperties": true
    },
    "bindingExpression": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["cfdl", "service", "automation", "localState", "constant"]
        },
        "ref": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "expression": {
          "type": "string"
        },
        "default": {},
        "schema": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "layout": {
      "type": "object",
      "required": ["id", "type"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_.-]+$"
        },
        "type": {
          "type": "string",
          "enum": ["page", "section", "grid", "stack", "slot"]
        },
        "title": {
          "type": "string"
        },
        "props": {
          "type": "object",
          "additionalProperties": true
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/layoutChild"
          }
        },
        "bindings": {
          "$ref": "#/$defs/bindings"
        },
        "condition": {
          "$ref": "#/$defs/conditional"
        }
      },
      "additionalProperties": false
    },
    "layoutChild": {
      "type": "object",
      "required": ["ref"],
      "properties": {
        "ref": {
          "type": "string",
          "description": "Component or layout reference ID"
        },
        "slot": {
          "type": "string"
        },
        "condition": {
          "$ref": "#/$defs/conditional"
        }
      },
      "additionalProperties": false
    },
    "conditional": {
      "type": "object",
      "properties": {
        "language": {
          "type": "string",
          "enum": ["cel", "spel", "javascript", "jq"]
        },
        "expression": {
          "type": "string"
        }
      },
      "required": ["language", "expression"],
      "additionalProperties": false
    },
    "bindings": {
      "type": "object",
      "properties": {
        "queries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/queryBinding"
          }
        },
        "mutations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/mutationBinding"
          }
        },
        "connectors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/connectorBinding"
          }
        }
      },
      "additionalProperties": false
    },
    "queryBinding": {
      "type": "object",
      "required": ["id", "type", "ref"],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["graphql", "rest", "localState"]
        },
        "ref": {
          "type": "string",
          "description": "Persisted query ID, REST endpoint, or local state key."
        },
        "variables": {
          "type": "object",
          "additionalProperties": true
        },
        "cachePolicy": {
          "type": "string",
          "enum": ["network-only", "network-first", "cache-first"]
        }
      },
      "additionalProperties": false
    },
    "mutationBinding": {
      "type": "object",
      "required": ["id", "type", "ref"],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["graphql", "rest", "automation"]
        },
        "ref": {
          "type": "string"
        },
        "inputMapping": {
          "type": "object",
          "additionalProperties": true
        },
        "onSuccess": {
          "$ref": "#/$defs/actionSequence"
        },
        "onError": {
          "$ref": "#/$defs/actionSequence"
        }
      },
      "additionalProperties": false
    },
    "connectorBinding": {
      "type": "object",
      "required": ["id", "connectorKey"],
      "properties": {
        "id": {
          "type": "string"
        },
        "connectorKey": {
          "type": "string"
        },
        "inputs": {
          "type": "object",
          "additionalProperties": true
        },
        "outputs": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "actionSequence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/action"
      }
    },
    "action": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "navigate",
            "emitEvent",
            "runMutation",
            "showToast",
            "updateState"
          ]
        },
        "target": {
          "type": "string"
        },
        "payload": {
          "type": "object",
          "additionalProperties": true
        },
        "condition": {
          "$ref": "#/$defs/conditional"
        }
      },
      "additionalProperties": false
    },
    "route": {
      "type": "object",
      "required": ["path", "layout"],
      "properties": {
        "path": {
          "type": "string"
        },
        "layout": {
          "type": "string",
          "description": "Layout ID"
        },
        "title": {
          "type": "string"
        },
        "guards": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/guard"
          }
        },
        "seo": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "guard": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["role", "attribute", "expression", "devMode"]
        },
        "value": {
          "type": "string"
        },
        "condition": {
          "$ref": "#/$defs/conditional"
        }
      },
      "additionalProperties": false
    },
    "workflowRef": {
      "type": "object",
      "required": ["cfdlRef", "taskId", "form"],
      "properties": {
        "cfdlRef": {
          "type": "string",
          "pattern": "^[\\w.-]+@[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "taskId": {
          "type": "string"
        },
        "form": {
          "type": "string",
          "description": "Component ID or layout that renders the task form"
        },
        "options": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "assets": {
      "type": "object",
      "properties": {
        "media": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fonts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    }
  }
}
