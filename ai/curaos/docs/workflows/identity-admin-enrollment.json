{
  "$schema": "https://schemas.curaos.dev/cfdl/v1.json",
  "id": "identity.admin-enrollment",
  "version": "1.0.0",
  "metadata": {
    "name": "Identity — Admin Enrollment",
    "description": "Handles provisioning a new tenant administrator, including verification and MFA setup.",
    "tags": [
      "identity",
      "admin-onboarding"
    ],
    "tenantScope": "tenant",
    "owner": "identity-service"
  },
  "context": {
    "inputs": {
      "invitationCode": "string",
      "tenantId": "uuid",
      "email": "string"
    },
    "outputs": {
      "accountId": "uuid",
      "mfaConfigured": "boolean"
    },
    "variables": {
      "verificationStatus": "string",
      "auditRef": "string"
    }
  },
  "graph": {
    "nodes": [
      {
        "id": "start_received_invite",
        "type": "start.event",
        "name": "Invitation Received",
        "lane": "system",
        "metadata": {
          "event": "identity.invitation.accepted"
        }
      },
      {
        "id": "user_task_profile",
        "type": "user.task",
        "name": "Collect Profile Details",
        "lane": "actor",
        "taskRef": "ui.form.identity.profile",
        "ioBindings": {
          "input": {
            "profile": {
              "type": "object",
              "schema": {
                "ref": "cbcfs://identity.hosted-login/forms/profile"
              }
            }
          },
          "output": {
            "profile": "json"
          }
        }
      },
      {
        "id": "service_task_verify_email",
        "type": "service.task",
        "name": "Verify Email",
        "lane": "system",
        "taskRef": "svc.identity.verify-email",
        "ioBindings": {
          "input": {
            "email": "string",
            "tenantId": "uuid"
          },
          "output": {
            "verificationStatus": "string"
          }
        }
      },
      {
        "id": "exclusive_gateway_verification",
        "type": "exclusive.gateway",
        "name": "Verification Result"
      },
      {
        "id": "user_task_setup_mfa",
        "type": "user.task",
        "name": "Configure MFA",
        "lane": "actor",
        "taskRef": "ui.form.identity.mfa",
        "ioBindings": {
          "output": {
            "mfaConfigured": "boolean"
          }
        }
      },
      {
        "id": "service_task_emit_audit",
        "type": "service.task",
        "name": "Emit Audit Event",
        "lane": "system",
        "taskRef": "svc.audit.append",
        "ioBindings": {
          "input": {
            "actor": "string",
            "action": "string",
            "resource": "string"
          },
          "output": {
            "auditRef": "string"
          }
        }
      },
      {
        "id": "end_complete",
        "type": "end.event",
        "name": "Enrollment Complete"
      },
      {
        "id": "end_failure",
        "type": "end.event",
        "name": "Verification Failed"
      }
    ],
    "edges": [
      {
        "id": "edge_start_to_profile",
        "source": "start_received_invite",
        "target": "user_task_profile"
      },
      {
        "id": "edge_profile_to_verify",
        "source": "user_task_profile",
        "target": "service_task_verify_email"
      },
      {
        "id": "edge_verify_to_gateway",
        "source": "service_task_verify_email",
        "target": "exclusive_gateway_verification"
      },
      {
        "id": "edge_gateway_to_mfa",
        "source": "exclusive_gateway_verification",
        "target": "user_task_setup_mfa",
        "metadata": {
          "condition": "verificationStatus == 'verified'"
        }
      },
      {
        "id": "edge_gateway_to_failure",
        "source": "exclusive_gateway_verification",
        "target": "end_failure",
        "metadata": {
          "condition": "verificationStatus != 'verified'"
        }
      },
      {
        "id": "edge_mfa_to_audit",
        "source": "user_task_setup_mfa",
        "target": "service_task_emit_audit"
      },
      {
        "id": "edge_audit_to_end",
        "source": "service_task_emit_audit",
        "target": "end_complete"
      }
    ]
  },
  "forms": [
    {
      "id": "form_identity_profile",
      "name": "Identity Profile Form",
      "schema": {
        "type": "object",
        "properties": {
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          }
        },
        "required": [
          "firstName",
          "lastName",
          "email"
        ]
      }
    }
  ],
  "policies": {
    "sla": "P2D",
    "escalations": [
      {
        "after": "PT4H",
        "action": "notify.identity.escalation"
      }
    ]
  }
}
