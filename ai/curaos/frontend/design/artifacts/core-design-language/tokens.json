{
  "$schema": "https://design-tokens.org/tokens.json",
  "_meta": {
    "name": "CuraOS Design System — Aqua",
    "version": "0.1.0",
    "description": "Fresh-modern brand for CuraOS. Bluish-aqua primary (healthcare-grade calm trust + platform-tech confidence). Neutrals are cool slate-grey, not the legacy slate+blue. Status colors carry saturation; primary stays the single brand voice. W3C design tokens, light + dark, per-tenant override via primary ramp swap.",
    "format": "W3C Design Tokens Community Group draft + Style Dictionary"
  },

  "color": {
    "primary": {
      "$type": "color",
      "_note": "Blue brand ramp. Tenant override = swap this ramp; everything else derives from semantic aliases.",
      "50":  { "$value": "#e8fbff" },
      "100": { "$value": "#c4f1fb" },
      "200": { "$value": "#91e2f3" },
      "300": { "$value": "#4fcbe8" },
      "400": { "$value": "#1fb0d4" },
      "500": { "$value": "#0e90b8" },
      "600": { "$value": "#0d7197" },
      "700": { "$value": "#105a7c" },
      "800": { "$value": "#114863" },
      "900": { "$value": "#0c2f44" }
    },

    "neutral": {
      "$type": "color",
      "_note": "Cool slate-teal ink ramp. Hint of green keeps it consonant with primary without being blue.",
      "0":   { "$value": "#ffffff" },
      "50":  { "$value": "#f6f8f8" },
      "100": { "$value": "#eceff0" },
      "200": { "$value": "#dde2e3" },
      "300": { "$value": "#c4cccd" },
      "400": { "$value": "#9aa5a7" },
      "500": { "$value": "#6e797b" },
      "600": { "$value": "#525c5e" },
      "700": { "$value": "#3c4547" },
      "800": { "$value": "#262d2e" },
      "900": { "$value": "#161b1c" },
      "950": { "$value": "#0d1112" }
    },

    "success": {
      "$type": "color",
      "50": { "$value": "#e7f8ec" }, "100": { "$value": "#c2edcf" },
      "200": { "$value": "#8edcab" }, "300": { "$value": "#52c47f" },
      "400": { "$value": "#2aa860" }, "500": { "$value": "#188a4c" },
      "600": { "$value": "#136f3e" }, "700": { "$value": "#115a34" },
      "800": { "$value": "#0f4729" }, "900": { "$value": "#0b371f" }
    },
    "warning": {
      "$type": "color",
      "50": { "$value": "#fdf4e3" }, "100": { "$value": "#f9e3b8" },
      "200": { "$value": "#f3cb78" }, "300": { "$value": "#ecae35" },
      "400": { "$value": "#d8920f" }, "500": { "$value": "#b3760a" },
      "600": { "$value": "#925f0b" }, "700": { "$value": "#774d0d" },
      "800": { "$value": "#5d3d0e" }, "900": { "$value": "#46300d" }
    },
    "error": {
      "$type": "color",
      "50": { "$value": "#fdeceb" }, "100": { "$value": "#f9cfcc" },
      "200": { "$value": "#f1a5a0" }, "300": { "$value": "#e5746c" },
      "400": { "$value": "#d44b41" }, "500": { "$value": "#bb3328" },
      "600": { "$value": "#992820" }, "700": { "$value": "#7c211b" },
      "800": { "$value": "#621c18" }, "900": { "$value": "#4b1714" }
    },
    "info": {
      "$type": "color",
      "_note": "Cyan-leaning info, kept distinct from blue primary by being bluer/brighter.",
      "50": { "$value": "#e8f4fb" }, "100": { "$value": "#c5e3f5" },
      "200": { "$value": "#92cbed" }, "300": { "$value": "#52ade0" },
      "400": { "$value": "#2191cf" }, "500": { "$value": "#1276ad" },
      "600": { "$value": "#0f608c" }, "700": { "$value": "#0e4e72" },
      "800": { "$value": "#0d3e5b" }, "900": { "$value": "#0a3046" }
    }
  },

  "semantic": {
    "_note": "Aliases consumed by components. Light + dark sets. This is the layer apps read; ramps above are raw material.",
    "light": {
      "bg":            { "$type": "color", "$value": "{color.neutral.50}" },
      "bg.subtle":     { "$type": "color", "$value": "{color.neutral.100}" },
      "surface":       { "$type": "color", "$value": "{color.neutral.0}" },
      "surface.raised":{ "$type": "color", "$value": "{color.neutral.0}" },
      "surface.sunken":{ "$type": "color", "$value": "{color.neutral.100}" },
      "line":          { "$type": "color", "$value": "{color.neutral.200}" },
      "line.strong":   { "$type": "color", "$value": "{color.neutral.300}" },
      "fg":            { "$type": "color", "$value": "{color.neutral.900}" },
      "fg.muted":      { "$type": "color", "$value": "{color.neutral.600}" },
      "fg.subtle":     { "$type": "color", "$value": "{color.neutral.500}" },
      "fg.onPrimary":  { "$type": "color", "$value": "{color.neutral.0}" },
      "primary":       { "$type": "color", "$value": "{color.primary.600}" },
      "primary.hover": { "$type": "color", "$value": "{color.primary.700}" },
      "primary.active":{ "$type": "color", "$value": "{color.primary.800}" },
      "primary.subtle":{ "$type": "color", "$value": "{color.primary.50}" },
      "primary.fg":    { "$type": "color", "$value": "{color.primary.700}" },
      "focus.ring":    { "$type": "color", "$value": "{color.primary.500}" },
      "success.fg": { "$type": "color", "$value": "{color.success.700}" },
      "success.bg": { "$type": "color", "$value": "{color.success.50}" },
      "warning.fg": { "$type": "color", "$value": "{color.warning.700}" },
      "warning.bg": { "$type": "color", "$value": "{color.warning.50}" },
      "error.fg":   { "$type": "color", "$value": "{color.error.600}" },
      "error.bg":   { "$type": "color", "$value": "{color.error.50}" },
      "info.fg":    { "$type": "color", "$value": "{color.info.600}" },
      "info.bg":    { "$type": "color", "$value": "{color.info.50}" }
    },
    "dark": {
      "bg":            { "$type": "color", "$value": "{color.neutral.950}" },
      "bg.subtle":     { "$type": "color", "$value": "{color.neutral.900}" },
      "surface":       { "$type": "color", "$value": "{color.neutral.900}" },
      "surface.raised":{ "$type": "color", "$value": "{color.neutral.800}" },
      "surface.sunken":{ "$type": "color", "$value": "{color.neutral.950}" },
      "line":          { "$type": "color", "$value": "#2c3537" },
      "line.strong":   { "$type": "color", "$value": "#3c4547" },
      "fg":            { "$type": "color", "$value": "{color.neutral.100}" },
      "fg.muted":      { "$type": "color", "$value": "{color.neutral.400}" },
      "fg.subtle":     { "$type": "color", "$value": "{color.neutral.500}" },
      "fg.onPrimary":  { "$type": "color", "$value": "{color.neutral.950}" },
      "primary":       { "$type": "color", "$value": "{color.primary.400}" },
      "primary.hover": { "$type": "color", "$value": "{color.primary.300}" },
      "primary.active":{ "$type": "color", "$value": "{color.primary.200}" },
      "primary.subtle":{ "$type": "color", "$value": "#0a2030" },
      "primary.fg":    { "$type": "color", "$value": "{color.primary.300}" },
      "focus.ring":    { "$type": "color", "$value": "{color.primary.400}" },
      "success.fg": { "$type": "color", "$value": "{color.success.300}" },
      "success.bg": { "$type": "color", "$value": "#0f2e1d" },
      "warning.fg": { "$type": "color", "$value": "{color.warning.300}" },
      "warning.bg": { "$type": "color", "$value": "#352608" },
      "error.fg":   { "$type": "color", "$value": "{color.error.300}" },
      "error.bg":   { "$type": "color", "$value": "#3a1714" },
      "info.fg":    { "$type": "color", "$value": "{color.info.300}" },
      "info.bg":    { "$type": "color", "$value": "#0c2e44" }
    }
  },

  "font": {
    "family": {
      "sans": { "$type": "fontFamily", "$value": ["Inter", "-apple-system", "BlinkMacSystemFont", "Segoe UI", "Roboto", "Helvetica Neue", "Arial", "sans-serif"] },
      "mono": { "$type": "fontFamily", "$value": ["JetBrains Mono", "SF Mono", "ui-monospace", "Menlo", "Consolas", "monospace"] }
    },
    "weight": {
      "regular":  { "$type": "fontWeight", "$value": 400 },
      "medium":   { "$type": "fontWeight", "$value": 500 },
      "semibold": { "$type": "fontWeight", "$value": 600 }
    }
  },

  "typescale": {
    "$type": "dimension",
    "display":  { "size": { "$value": "44px" }, "line": { "$value": "1.1" },  "weight": { "$value": 600 }, "tracking": { "$value": "-0.02em" } },
    "h1":       { "size": { "$value": "32px" }, "line": { "$value": "1.2" },  "weight": { "$value": 600 }, "tracking": { "$value": "-0.015em" } },
    "h2":       { "size": { "$value": "25px" }, "line": { "$value": "1.25" }, "weight": { "$value": 600 }, "tracking": { "$value": "-0.01em" } },
    "h3":       { "size": { "$value": "20px" }, "line": { "$value": "1.3" },  "weight": { "$value": 600 }, "tracking": { "$value": "-0.005em" } },
    "h4":       { "size": { "$value": "16px" }, "line": { "$value": "1.4" },  "weight": { "$value": 600 }, "tracking": { "$value": "0" } },
    "body":     { "size": { "$value": "15px" }, "line": { "$value": "1.55" }, "weight": { "$value": 400 }, "tracking": { "$value": "0" } },
    "body-sm":  { "size": { "$value": "13px" }, "line": { "$value": "1.5" },  "weight": { "$value": 400 }, "tracking": { "$value": "0.005em" } },
    "caption":  { "size": { "$value": "12px" }, "line": { "$value": "1.4" },  "weight": { "$value": 500 }, "tracking": { "$value": "0.01em" } },
    "code":     { "size": { "$value": "13px" }, "line": { "$value": "1.5" },  "weight": { "$value": 400 }, "tracking": { "$value": "0" } }
  },

  "space": {
    "$type": "dimension",
    "0": { "$value": "0px" }, "1": { "$value": "4px" }, "2": { "$value": "8px" },
    "3": { "$value": "12px" }, "4": { "$value": "16px" }, "5": { "$value": "20px" },
    "6": { "$value": "24px" }, "8": { "$value": "32px" }, "10": { "$value": "40px" },
    "12": { "$value": "48px" }, "16": { "$value": "64px" }, "20": { "$value": "80px" }
  },

  "radius": {
    "$type": "dimension",
    "none": { "$value": "0px" }, "sm": { "$value": "4px" }, "md": { "$value": "8px" },
    "lg": { "$value": "12px" }, "xl": { "$value": "16px" }, "full": { "$value": "9999px" }
  },

  "elevation": {
    "$type": "shadow",
    "0": { "$value": "none" },
    "1": { "$value": "0 1px 2px rgba(13,17,18,0.06), 0 1px 1px rgba(13,17,18,0.04)" },
    "2": { "$value": "0 2px 4px rgba(13,17,18,0.06), 0 4px 8px rgba(13,17,18,0.06)" },
    "3": { "$value": "0 6px 12px rgba(13,17,18,0.08), 0 12px 24px rgba(13,17,18,0.08)" },
    "4": { "$value": "0 12px 24px rgba(13,17,18,0.10), 0 24px 48px rgba(13,17,18,0.12)" }
  },

  "motion": {
    "duration": {
      "$type": "duration",
      "instant": { "$value": "80ms" }, "fast": { "$value": "140ms" },
      "base": { "$value": "200ms" }, "slow": { "$value": "320ms" }
    },
    "easing": {
      "standard": { "$type": "cubicBezier", "$value": [0.2, 0, 0, 1] },
      "decelerate": { "$type": "cubicBezier", "$value": [0, 0, 0, 1] },
      "accelerate": { "$type": "cubicBezier", "$value": [0.3, 0, 1, 1] }
    }
  },

  "zIndex": {
    "$type": "number",
    "base": { "$value": 0 }, "dropdown": { "$value": 1000 }, "sticky": { "$value": 1100 },
    "drawer": { "$value": 1200 }, "modal": { "$value": 1300 }, "toast": { "$value": 1400 },
    "tooltip": { "$value": 1500 }, "command": { "$value": 1600 }
  },

  "breakpoint": {
    "$type": "dimension",
    "sm": { "$value": "640px" }, "md": { "$value": "768px" }, "lg": { "$value": "1024px" },
    "xl": { "$value": "1280px" }, "2xl": { "$value": "1536px" }
  }
}
