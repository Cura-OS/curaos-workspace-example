#!/usr/bin/env bash
# preflight-credentials: credential preflight for deploy-class lanes (RP-52).
#
# Run BEFORE dispatching any lane that builds/publishes images or signs
# artifacts. Converts the session-36 WALL 1 class (gh OAuth token missing
# write:packages, discovered MID-execution after hours of build work) into a
# pre-dispatch hard stop. Two checks:
#
#   1. Token scopes (always): the GitHub API response header X-OAuth-Scopes
#      must contain EVERY required scope (default write:packages,read:packages).
#      Cannot-prove is BLOCKED, not a pass: an API failure or an absent header
#      (fine-grained PATs / app tokens do not expose scopes) exits 70 per the
#      RP-14 fail-closed doctrine. A present-but-empty header is a provable
#      zero-scope token and exits 65.
#   2. Registry write (--registry-probe): push a real scratch tag to
#      <image-repo>:preflight-<utc-stamp>. docker login "Succeeded" is a KNOWN
#      FALSE POSITIVE (session-36: login succeeded, push 403'd); login is
#      performed only as setup and NEVER counted as proof. The push is the
#      proof. The scratch tag is left on the registry (deleting needs
#      delete:packages); operators may prune ghcr.io/<owner>/preflight-scratch.
#
# Usage:
#   preflight-credentials [--scopes CSV] [--registry-probe] [--image-repo REPO]
#     --scopes CSV       required token scopes (default write:packages,read:packages)
#     --registry-probe   also prove registry write with a scratch-tag push
#     --image-repo REPO  scratch image repo for the probe
#                        (default ghcr.io/cura-care-oriented-stack/preflight-scratch)
#
# Exit: 0 all requested checks proved; 2 usage;
#       65 required scope missing; 66 registry write rejected;
#       70 cannot prove (API/header/tooling failure; fail closed).
set -uo pipefail

REQUIRED_SCOPES="write:packages,read:packages"
REGISTRY_PROBE=0
IMAGE_REPO="ghcr.io/cura-care-oriented-stack/preflight-scratch"

while [ $# -gt 0 ]; do
  case "$1" in
    --scopes) REQUIRED_SCOPES="${2:?--scopes needs a CSV value}"; shift ;;
    --registry-probe) REGISTRY_PROBE=1 ;;
    --image-repo) IMAGE_REPO="${2:?--image-repo needs a value}"; shift ;;
    -h|--help) sed -n '2,32p' "$0"; exit 0 ;;
    *) echo "unknown arg: $1" >&2; exit 2 ;;
  esac
  shift
done

# Agent shells can carry a narrow GITHUB_TOKEN that lacks org scope. Unset it
# so gh uses GH_TOKEN or the project-scoped keyring login (workspace pattern).
gh() { env -u GITHUB_TOKEN command gh "$@"; }

# --- Check 1: token scopes via the X-OAuth-Scopes response header ---------
if ! RESP="$(gh api -i -X GET user 2>&1)"; then
  echo "preflight-credentials: GitHub API probe failed: $RESP" >&2
  echo "preflight-credentials: BLOCKED, cannot prove token scopes (fail closed)" >&2
  exit 70
fi

SCOPE_HEADER="$(printf '%s\n' "$RESP" | tr -d '\r' | grep -i '^x-oauth-scopes:' | head -1)"
if [ -z "$SCOPE_HEADER" ]; then
  echo "preflight-credentials: X-OAuth-Scopes header ABSENT (fine-grained PAT / app token does not expose scopes)" >&2
  echo "preflight-credentials: BLOCKED, cannot prove token scopes (fail closed)" >&2
  exit 70
fi
# Header value keeps inner colons (write:packages): cut field 2..end.
SCOPES_CSV="$(printf '%s' "$SCOPE_HEADER" | cut -d: -f2- | tr -d ' ')"

MISSING=""
IFS=',' read -r -a REQ_ARR <<< "$REQUIRED_SCOPES"
for scope in "${REQ_ARR[@]}"; do
  [ -z "$scope" ] && continue
  if ! printf '%s' ",$SCOPES_CSV," | grep -qF ",$scope,"; then
    MISSING="$MISSING $scope"
  fi
done

if [ -n "$MISSING" ]; then
  echo "preflight-credentials: token scopes [$SCOPES_CSV] MISSING:$MISSING" >&2
  echo "preflight-credentials: unblock: gh auth refresh -h github.com -s write:packages,read:packages" >&2
  exit 65
fi
echo "preflight-credentials: token scopes OK [$SCOPES_CSV] cover required [$REQUIRED_SCOPES]"

# --- Check 2 (opt-in): registry write proved by a real scratch-tag push ---
if [ "$REGISTRY_PROBE" -eq 1 ]; then
  if ! command -v docker >/dev/null 2>&1; then
    echo "preflight-credentials: docker not found; BLOCKED, cannot prove registry write (fail closed)" >&2
    exit 70
  fi

  STAMP="$(date -u +%Y%m%dT%H%M%SZ)"
  TAG="$IMAGE_REPO:preflight-$STAMP"
  CTX="$(mktemp -d)"
  trap 'rm -rf "$CTX"' EXIT
  printf 'preflight scratch %s\n' "$STAMP" > "$CTX/stamp"
  printf 'FROM scratch\nCOPY stamp /stamp\n' > "$CTX/Dockerfile"

  if ! BUILD_OUT="$(docker build -q -t "$TAG" "$CTX" 2>&1)"; then
    echo "preflight-credentials: scratch image build failed: $BUILD_OUT" >&2
    echo "preflight-credentials: BLOCKED, cannot prove registry write (fail closed)" >&2
    exit 70
  fi

  # Login is setup only. Its success is NEVER the verdict (session-36 false
  # positive: "Login Succeeded" with a push-rejecting token).
  REGISTRY_HOST="${IMAGE_REPO%%/*}"
  if TOKEN="$(gh auth token 2>/dev/null)" && [ -n "$TOKEN" ]; then
    printf '%s' "$TOKEN" | docker login "$REGISTRY_HOST" -u oauth --password-stdin >/dev/null 2>&1 || true
  fi

  if ! PUSH_OUT="$(docker push "$TAG" 2>&1)"; then
    echo "preflight-credentials: registry write FAILED: scratch-tag push to $TAG rejected" >&2
    echo "$PUSH_OUT" | tail -3 >&2
    echo "preflight-credentials: login success does not count; the push is the proof" >&2
    exit 66
  fi
  docker rmi "$TAG" >/dev/null 2>&1 || true
  echo "preflight-credentials: registry write OK (pushed scratch tag $TAG)"
fi

echo "preflight-credentials: PASS"
